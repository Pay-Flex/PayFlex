<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Cleartext HTTP autorisé UNIQUEMENT en debug, pour tester en local
         (USB/LAN via PAYFLEX_API_HOST) contre un backend sans HTTPS. Fusionné
         par le manifest merger dans l'application déclarée en src/main ;
         absent en release, où seul HTTPS est autorisé. -->
    <application android:usesCleartextTraffic="true" />
</manifest>
