# Copiez ce fichier en « .env » et remplissez vos valeurs.
# Ne commitez JAMAIS le fichier .env (déjà dans .gitignore).

# FedaPay sandbox (clé secrète = sk_… uniquement côté serveur)
FEDAPAY_API_KEY=sk_sandbox_votre_cle_secrete
FEDAPAY_PUBLIC_KEY=pk_sandbox_votre_cle_publique
FEDAPAY_WEBHOOK_SECRET=wh_sandbox_votre_secret_webhook
FEDAPAY_SANDBOX=true
FEDAPAY_ENABLED=true

# URL publique du backend (webhooks FedaPay, callbacks, liens absolus).
# Dev mobile : préférez Wi-Fi ou USB — voir TUNNEL.md (pas de tunnel nécessaire).
# HTTPS public fixe : tunnel Cloudflare nommé + domaine, ou serveur déployé.
# Quick tunnel temporaire : cloudflared tunnel --url http://localhost:8088
PAYFLEX_PUBLIC_URL=http://192.168.1.68:8088

# Base de données (optionnel)
# PAYFLEX_DB_URL=jdbc:mysql://localhost:3306/payflexdb?...
# PAYFLEX_DB_USER=root
# PAYFLEX_DB_PASSWORD=
