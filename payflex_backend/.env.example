# Copiez ce fichier en « .env » et remplissez vos valeurs.
# Ne commitez JAMAIS le fichier .env (déjà dans .gitignore).

# ---------------------------------------------------------------------------
# PayDunya (passerelle mobile money unique : Flooz Moov, T-Money / Mixx by Yas, cartes)
# API « Checkout Invoice » (Paiement Avec Redirection). Repli gracieux : si ces clés
# sont vides, le mobile money est masqué côté mobile (déclaration classique / espèces).
# Clés : compte PayDunya Business → « Intégrez notre API » → configurer une application.
# ---------------------------------------------------------------------------
PAYDUNYA_ENABLED=true
# test = sandbox PayDunya (aucun argent réel) ; live = production.
PAYDUNYA_MODE=test
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
# Clé publique optionnelle (intégration côté client) — laisser vide si non utilisée.
PAYDUNYA_PUBLIC_KEY=

# URL publique du backend (webhook/IPN PayDunya, admin HTTPS via tunnel, liens absolus).
# Dev local Wi-Fi / USB : laisser vide ou http://192.168.x.x:8088 (voir TUNNEL.md).
# Dev tunnel LocalTunnel : https://payflex-app.loca.lt (même URL que l'app mobile).
# Production : https://api.votredomaine.com (domaine fixe, pas de loca.lt).
# Quick tunnel temporaire : cloudflared tunnel --url http://localhost:8088
PAYFLEX_PUBLIC_URL=https://payflex-app.loca.lt

# Collecte espèces agent : false = en attente jusqu'au rapprochement fin de journée (admin)
# PAYFLEX_AGENT_CASH_AUTO_VALIDATE=false

# ---------------------------------------------------------------------------
# NOTIFICATIONS PUSH RÉELLES (optionnel — voir PAYFLEX_PUSH.md)
# Si laissé vide, l'app retombe automatiquement sur le modèle « pull »
# (poll mobile + inbox admin). Aucune de ces clés n'est un secret partageable.
# ---------------------------------------------------------------------------
# 1) Mobile — Firebase Cloud Messaging (FCM)
#    Chemin ABSOLU vers le fichier JSON du compte de service Firebase
#    (Console Firebase → Paramètres du projet → Comptes de service → Générer une clé).
# PAYFLEX_FIREBASE_CREDENTIALS=C:/secrets/payflex-firebase-service-account.json

# 2) Admin/support — Web Push (VAPID) pour notifications navigateur sur les postes bureau.
#    Générer une paire de clés VAPID (voir PAYFLEX_PUSH.md), puis renseigner :
# PAYFLEX_VAPID_PUBLIC_KEY=
# PAYFLEX_VAPID_PRIVATE_KEY=
# PAYFLEX_VAPID_SUBJECT=mailto:support@payflex.app

# Base de données (optionnel)
# PAYFLEX_DB_URL=jdbc:mysql://localhost:3306/payflexdb?...
# PAYFLEX_DB_USER=root
# PAYFLEX_DB_PASSWORD=
